{
  "name": "sound-tank",
  "version": "2.3.0",
  "private": false,
  "description": "A library for interacting with the Reverb Marketplace API",
  "license": "MIT",
  "author": "Zachary Eggert <Eggert.Zachary@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZacharyEggert/sound-tank.git"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "dev": "vitest",
    "test": "vitest run",
    "test:sandbox": "vitest run --config vitest.sandbox.config.mts",
    "build": "tsup --config tsup.config.ts",
    "lint": "tsc",
    "ci": "yarn install --frozen-lockfile && yarn lint && yarn test && yarn build",
    "release": "yarn lint && yarn test && yarn build && changeset publish",
    "fmt": "prettier --write ."
  },
  "dependencies": {},
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "dotenv": "^17.4.2",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
